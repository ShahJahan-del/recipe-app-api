# Database Configuration (e.g., Supabase or local Postgres)
DB_HOST=localhost
DB_NAME=postgres
DB_USER=postgres
DB_PASS=changeme
DB_PORT=5432

# Django Security Settings
# Generate a unique secret key for each environment
DJANGO_SECRET_KEY=changeme

# Allowed hosts/domains, separated by commas (strictly NO spaces)
# For local development: 127.0.0.1,localhost
# For production: aws_ip, aws_public_dns
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost